 RewriteEngine On

# Redirect everything to coming soon (root index.html)
RewriteCond %{REQUEST_URI} !^/$
RewriteCond %{REQUEST_URI} !^/index\.html$
RewriteRule ^(.*)$ / [R=302,L]

# Fix Google's automatic sitelinks
RewriteRule ^gallery/?$ /pt/inspiracao.html [R=301,L]
RewriteRule ^products/?$ /pt/ceramica-shop.html [R=301,L]